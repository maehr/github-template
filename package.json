{
	"name": "moritzmaehr.ch",
	"description": "Digital tales: personal weblog of Moritz Mähr.",
	"author": "Moritz Mähr <moritz.maehr@gmail.com>",
	"version": "0.0.1",
	"url": "https://github.com/maehr/moritzmaehr.ch/issues",
	"license": "AGPL-3.0",
	"scripts": {
		"check": "prettier --ignore-path .gitignore --check . '!{CODE_OF_CONDUCT.md,LICENSE-AGPL.md,LICENSE-CCBYSA.md}'",
		"commit": "cz",
		"format": "prettier --ignore-path .gitignore --write . '!{CODE_OF_CONDUCT.md,LICENSE-AGPL.md,LICENSE-CCBYSA.md}'",
		"prepare": "husky"
	},
	"devDependencies": {
		"commitizen": "^4.3.0",
		"cz-conventional-changelog": "^3.3.0",
		"husky": "^9.1.5",
		"prettier": "^3.3.3"
	},
	"type": "module",
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	}
}
